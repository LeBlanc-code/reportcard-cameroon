# --- Django Settings ---
SECRET_KEY=generate-a-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (uncomment to use PostgreSQL instead of SQLite) ---
# DATABASE_URL=postgres://user:password@localhost:5432/reportcard_db

# --- Security (set to False/0 for PythonAnywhere free tier - HTTP only) ---
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# --- Email (optional - uses console backend if not configured) ---
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
